#!/usr/bin/env bash
#
# Open myapp in a tmux popup, attaching to a persistent "myapp" session so its
# state survives closing the popup. The session is created on first use and runs
# the `myapp` shell function via a login+interactive shell (so volta/node and
# the function resolve). TMUX is unset for the attach to allow attaching to a
# session on the same server from inside tmux.
set -u
session="myapp"
if ! tmux has-session -t "=$session" 2>/dev/null; then
  tmux new-session -d -s "$session" "$SHELL -lic myapp"
  tmux set-option -t "$session" status off   # clean popup (no inner status bar)
fi
exec env -u TMUX tmux attach-session -t "$session"
